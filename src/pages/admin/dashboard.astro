---
// File: /src/pages/admin/dashboard.astro
import AdminLayout from '@/layouts/AdminLayout.astro';
import { requireAdmin } from '@/lib/adminAuth.ts';

const admin = await requireAdmin(Astro);
if (!admin.ok) {
  return Astro.redirect('/login');
}
---
<AdminLayout title="Admin Dashboard">
  <div class="space-y-6">
    <h1 class="text-3xl font-bold">Dashboard Analytics</h1>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
      <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-orange-500">
        <p class="text-sm text-slate-500">Total Pendapatan (30 hari)</p>
        <p id="total-revenue" class="text-2xl font-bold text-slate-800">-</p>
      </div>
      <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-blue-500">
        <p class="text-sm text-slate-500">Total Pesanan</p>
        <p id="total-orders" class="text-2xl font-bold text-slate-800">-</p>
      </div>
      <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-green-500">
        <p class="text-sm text-slate-500">Rata-rata Order</p>
        <p id="avg-order" class="text-2xl font-bold text-slate-800">-</p>
      </div>
      <div class="bg-white p-6 rounded-xl shadow-md border-l-4 border-purple-500">
        <p class="text-sm text-slate-500">Total Ongkir & Fee</p>
        <p id="shipping-fee" class="text-2xl font-bold text-slate-800">-</p>
      </div>
    </div>

    <div class="bg-white p-6 rounded-xl shadow-md">
      <h2 class="text-xl font-bold mb-4">Pendapatan Harian (30 hari terakhir)</h2>
      <div id="daily-chart" class="w-full h-64 flex items-end gap-1 overflow-x-auto pb-2"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white p-6 rounded-xl shadow-md">
        <h2 class="text-xl font-bold mb-4">Status Pesanan</h2>
        <div id="status-chart" class="space-y-2"></div>
      </div>
      <div class="bg-white p-6 rounded-xl shadow-md">
        <h2 class="text-xl font-bold mb-4">Produk Terlaris</h2>
        <div id="top-products" class="space-y-2"></div>
      </div>
    </div>
  </div>

  <script>
    const API_URL = '/api/admin/analytics';

    async function loadAnalytics() {
      const res = await fetch(API_URL);
      if (!res.ok) {
        console.error('Gagal memuat analytics');
        return;
      }
      const data = await res.json();

      const formatRupiah = (number) =>
        new Intl.NumberFormat('id-ID', {
          style: 'currency',
          currency: 'IDR',
          minimumFractionDigits: 0,
        }).format(number || 0);

      document.getElementById('total-revenue').textContent = formatRupiah(data.summary.totalRevenue);
      document.getElementById('total-orders').textContent = data.summary.totalOrders;
      document.getElementById('avg-order').textContent = formatRupiah(data.summary.avgOrderValue);
      document.getElementById('shipping-fee').textContent = formatRupiah(data.summary.shippingTotal + data.summary.gatewayFeeTotal);

      const dailyEntries = Object.entries(data.dailyRevenue || {}).sort((a, b) => a[0].localeCompare(b[0]));
      const dailyContainer = document.getElementById('daily-chart');
      if (dailyContainer) {
        dailyContainer.innerHTML = '';
        const max = Math.max(...dailyEntries.map(([, v]) => v), 1);
        dailyEntries.forEach(([date, value]) => {
          const heightPct = (value / max) * 100;
          const bar = document.createElement('div');
          bar.className = 'flex flex-col items-center gap-1 min-w-[40px]';
          bar.innerHTML = `
            <div class="w-full bg-orange-500 rounded-t-md hover:bg-orange-600 transition-colors" style="height:${Math.max(heightPct, 2)}%"></div>
            <span class="text-[10px] text-slate-500">${date.slice(5)}</span>
          `;
          dailyContainer.appendChild(bar);
        });
      }

      const statusContainer = document.getElementById('status-chart');
      if (statusContainer) {
        statusContainer.innerHTML = '';
        const entries = Object.entries(data.statusCounts || {});
        const maxCount = Math.max(...entries.map(([, v]) => v), 1);
        entries.forEach(([status, count]) => {
          const widthPct = (count / maxCount) * 100;
          const row = document.createElement('div');
          row.className = 'flex items-center gap-3';
          row.innerHTML = `
            <span class="w-32 text-sm font-medium text-slate-700 capitalize">${status.replace(/_/g, ' ')}</span>
            <div class="flex-grow bg-slate-100 rounded-full h-4 overflow-hidden">
              <div class="bg-blue-500 h-full rounded-full" style="width:${widthPct}%"></div>
            </div>
            <span class="text-sm font-bold text-slate-800 w-12 text-right">${count}</span>
          `;
          statusContainer.appendChild(row);
        });
      }

      const topContainer = document.getElementById('top-products');
      if (topContainer) {
        topContainer.innerHTML = '';
        const products = data.topProducts || [];
        if (!products.length) {
          topContainer.innerHTML = '<p class="text-sm text-slate-500">Belum ada data penjualan.</p>';
        }
        products.forEach((product, idx) => {
          const row = document.createElement('div');
          row.className = 'flex items-center justify-between py-2 border-b last:border-b-0';
          row.innerHTML = `
            <div class="flex items-center gap-3">
              <span class="w-6 h-6 flex items-center justify-center rounded-full bg-orange-100 text-orange-700 text-xs font-bold">${idx + 1}</span>
              <span class="text-sm font-medium text-slate-800">${product.nama || product.merek || 'Produk'}</span>
            </div>
            <span class="text-sm font-bold text-slate-700">${product.total_terjual || 0} terjual</span>
          `;
          topContainer.appendChild(row);
        });
      }
    }

    loadAnalytics();
  </script>
</AdminLayout>
