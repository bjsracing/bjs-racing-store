# Supabase (lihat di Project Settings > API)
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Midtrans (mode Sandbox saat develop)
MIDTRANS_SERVER_KEY=your-midtrans-server-key
PUBLIC_MIDTRANS_CLIENT_KEY=your-midtrans-client-key

# RajaOngkir (lihat di https://rajaongkir.com/)
RAJAONGKIR_API_KEY=your-rajaongkir-api-key
RAJAONGKIR_ORIGIN_ID=your-store-origin-city-or-subdistrict-id
