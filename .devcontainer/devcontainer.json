{
  "name": "BJS Store",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "npm install -g opencode-ai supabase vercel uipro-cli && npm install",
  "forwardPorts": [
    4321
  ],
  "portsAttributes": {
    "4321": {
      "label": "Dev Server",
      "onAutoForward": "notify"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "astro-build.astro-vscode",
        "bradlc.vscode-tailwindcss",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
